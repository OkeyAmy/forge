# ── Model (required) ──────────────────────────────────────────────────────────
# Any OpenAI-compatible provider works. Pick one block below.

# OpenAI
# FORGE_MODEL=gpt-4o
# FORGE_BASE_URL=https://api.openai.com/v1
# FORGE_API_KEY=sk-...

# Google Gemini
FORGE_MODEL=models/gemini-2.0-flash-001
FORGE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
FORGE_API_KEY=AIza...

# Ollama (local)
# FORGE_MODEL=llama3
# FORGE_BASE_URL=http://host.docker.internal:11434/v1
# FORGE_API_KEY=ollama

# ── GitHub (recommended) ──────────────────────────────────────────────────────
# Raises the GitHub API rate limit from 60 to 5000 req/hr.
# Required for private repos.
GITHUB_TOKEN=ghp_...

# ── Docker (required for watch mode) ─────────────────────────────────────────
# Find your host Docker group GID:  getent group docker | cut -d: -f3
DOCKER_GID=999

# ── One-shot defaults (Method 1) ─────────────────────────────────────────────
FORGE_REPO=OkeyAmy/Axioschat-Onboard
FORGE_ISSUE=27

# ── Watch mode (Method 3) ─────────────────────────────────────────────────────
FORGE_WATCH_REPO=OkeyAmy/Axioschat-Onboard
FORGE_WATCH_LABEL=forge
FORGE_WATCH_INTERVAL=60
