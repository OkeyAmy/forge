# ============================================================
# Forge — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# ----------------------------------------------------------
# Required — model credentials (any OpenAI-compatible API)
# ----------------------------------------------------------
FORGE_MODEL=your-model-name
# Examples:
#   OpenAI:    gpt-4o
#   Gemini:    models/gemini-2.0-flash-001
#   Local:     llama3

FORGE_BASE_URL=https://your-provider.example.com/v1
# Examples:
#   OpenAI:   https://api.openai.com/v1
#   Gemini:   https://generativelanguage.googleapis.com/v1beta/openai
#   Local:    http://localhost:11434/v1

FORGE_API_KEY=your-api-key-here

# ----------------------------------------------------------
# One-shot mode (forge run / docker compose run forge)
# ----------------------------------------------------------
# The repo and issue number to fix.
FORGE_REPO=owner/repo
FORGE_ISSUE=1

# ----------------------------------------------------------
# Watch mode (docker compose up watch)
# ----------------------------------------------------------
# Repo to monitor for new issues.
FORGE_WATCH_REPO=owner/repo

# Only issues carrying this label will be picked up.
FORGE_WATCH_LABEL=forge

# Seconds between polls.
FORGE_WATCH_INTERVAL=60

# ----------------------------------------------------------
# Optional
# ----------------------------------------------------------
# GitHub Personal Access Token — raises API rate limit (recommended).
# Required for private repos.
# GITHUB_TOKEN=ghp_...

# Log verbosity: error | warn | info | debug
# RUST_LOG=forge=warn

# Docker group GID on the host (for docker-compose socket mount).
# Find it with: getent group docker | cut -d: -f3
# DOCKER_GID=999
