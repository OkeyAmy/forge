# Build output
/target

# Secrets — never commit
.env
*.key
*.pem
*.p12
*.pfx

# JavaScript / Next.js / pnpm (repo-wide — avoids committing node_modules or SWC binaries)
**/node_modules/
**/.pnpm-store/
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tsbuildinfo
landing/.next/
landing/out/
landing/.vercel/
.turbo/

# React Native / Expo (if you add a mobile app under this repo)
**/.expo/
**/dist/
.metro-health-check*
*.jks
*.p8
*.p12
*.mobileprovision
**/ios/Pods/
**/ios/build/
**/ios/*.xcworkspace/xcuserdata/
**/android/.gradle/
**/android/build/
**/android/app/build/
**/android/local.properties
**/*.hprof

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

